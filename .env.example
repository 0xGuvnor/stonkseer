# Vercel / Next.js — copy to .env.local or set in Vercel project settings.
# Convex backend vars: see .env.convex.example

# --- Convex client (required) ---
# Inlined at build time on Vercel; must be set per environment (production, preview, development).
NEXT_PUBLIC_CONVEX_URL=

# --- Clerk (required) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Anonymous research trial (optional) ---
# Dedicated HMAC secret for anonymous trial cookies. Falls back to CLERK_SECRET_KEY if unset.
ANONYMOUS_TOKEN_SECRET=
