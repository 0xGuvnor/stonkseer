NEXT_PUBLIC_CONVEX_URL=
CLERK_JWT_ISSUER_DOMAIN=
ANONYMOUS_TOKEN_SECRET=
FINNHUB_API_KEY=
AI_GATEWAY_MODEL=
AI_GATEWAY_API_KEY=
# Set on Convex deployment env (not Vercel): production | development | preview — tags Gateway spend by environment.
STONKSEER_GATEWAY_ENV=
# Optional merge/extraction failover models (comma-separated Gateway ids), e.g. anthropic/claude-sonnet-4.6,openai/gpt-5.4
AI_GATEWAY_EXTRACTION_FALLBACK_MODELS=
VERCEL_OIDC_TOKEN=
# Comma-separated hosted providers: gemini,openai,anthropic,xai
# When openai is listed, hosted search uses GPT (Gateway model id below) + Exa webSearch tool; set EXA_API_KEY.
CATALYST_HOSTED_SEARCH_PROVIDERS=
CATALYST_HOSTED_SEARCH_PROVIDER=
EXA_API_KEY=
# Gemini Google search grounding via AI Gateway (e.g. google/gemini-2.5-flash). Requires AI_GATEWAY_API_KEY or VERCEL_OIDC_TOKEN like other hosted models.
CATALYST_GEMINI_SEARCH_MODEL=
# GPT orchestrator for Exa tool-calling (e.g. openai/gpt-5.5 via AI Gateway)
CATALYST_OPENAI_SEARCH_MODEL=
# Optional: max generateText steps for GPT+Exa agent (default 5, min 2, max 25)
CATALYST_OPENAI_EXA_AGENT_MAX_STEPS=
CATALYST_ANTHROPIC_SEARCH_MODEL=
CATALYST_ANTHROPIC_WEB_SEARCH_MAX_USES=
CATALYST_XAI_SEARCH_MODEL=