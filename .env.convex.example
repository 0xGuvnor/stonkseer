# Convex deployment — set in Convex Dashboard → Settings → Environment Variables
# (or: bunx convex env set KEY value)
# Next.js / Vercel vars: see .env.example

# --- Auth (required) ---
# Clerk JWT template named "convex" — issuer domain from Clerk dashboard.
CLERK_JWT_ISSUER_DOMAIN=

# --- Research core ---
FINNHUB_API_KEY=
# Stable AI Gateway API key (required for research). Do not rely on VERCEL_OIDC_TOKEN here — OIDC tokens are Vercel-runtime-only and expire.
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=
# production | development | preview — tags Gateway spend by environment.
STONKSEER_GATEWAY_ENV=
# Optional merge/extraction failover models (comma-separated Gateway ids), e.g. anthropic/claude-sonnet-4.6,openai/gpt-5.4
AI_GATEWAY_EXTRACTION_FALLBACK_MODELS=

# --- Hosted search ---
# Comma-separated providers: gemini,openai,anthropic,xai
# Legacy alias CATALYST_HOSTED_SEARCH_PROVIDER (singular) is also accepted but deprecated.
# When openai is listed, hosted search uses GPT + Exa webSearch tool; set EXA_API_KEY.
CATALYST_HOSTED_SEARCH_PROVIDERS=
EXA_API_KEY=
# Gemini Google search grounding via AI Gateway (e.g. google/gemini-2.5-flash).
CATALYST_GEMINI_SEARCH_MODEL=
# GPT orchestrator for Exa tool-calling (e.g. openai/gpt-5.5 via AI Gateway).
CATALYST_OPENAI_SEARCH_MODEL=
# Optional: max generateText steps for GPT+Exa agent (default 8, min 2, max 25).
CATALYST_OPENAI_EXA_AGENT_MAX_STEPS=
CATALYST_ANTHROPIC_SEARCH_MODEL=
# Optional: max web search uses for Anthropic hosted search (default 8).
CATALYST_ANTHROPIC_WEB_SEARCH_MAX_USES=
CATALYST_XAI_SEARCH_MODEL=

# --- Follow-up / deep-read (optional) ---
# Follow-up query writer model; falls back to AI_GATEWAY_MODEL if unset.
CATALYST_FOLLOWUP_MODEL=
# Max targeted follow-up Exa queries (default 6).
CATALYST_FOLLOWUP_MAX_QUERIES=
# Exa Contents deep-read caps (defaults: 8 URLs, 8000 chars per URL).
CATALYST_DEEP_READ_MAX_URLS=
CATALYST_DEEP_READ_MAX_CHARACTERS=

# --- Dev-only ---
# Must be exactly "true" to run convex:devData:wipeAllRowsDev.
ALLOW_CONVEX_DEV_WIPE=
